* {
  box-sizing: border-box;
}

body {
  margin: 0;
  padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  background-color: #FAFAF8;
}

#root {
  min-height: 100dvh;
  display: flex;
  flex-direction: column;
}

/* CSS Custom Properties for Accessibility Modes */
:root {
  --vaani-bg: #FAFAF8;
  --vaani-text: #374151;
  --vaani-user-bubble: #1D9E75;
  --vaani-ai-bubble-bg: #FFFFFF;
  --vaani-ai-bubble-text: #111827;
  --vaani-border: #E5E7EB;
  --vaani-input-bg: #FFFFFF;
  --vaani-base-font-size: 15px;
  --vaani-bubble-padding: 12px;
}

/* Large Text Mode — only changes CSS variables */
.vaani-large-text {
  --vaani-base-font-size: 20px;
  --vaani-bubble-padding: 16px;
}

/* High Contrast Mode — only changes CSS variables */
.vaani-high-contrast {
  --vaani-bg: #FFFFFF;
  --vaani-text: #000000;
  --vaani-user-bubble: #1E3A5F;
  --vaani-ai-bubble-bg: #F0F0F0;
  --vaani-ai-bubble-text: #000000;
  --vaani-border: #333333;
  --vaani-input-bg: #FFFFFF;
}

html.vaani-high-contrast, html.vaani-high-contrast body {
  background-color: var(--vaani-bg) !important;
  color: var(--vaani-text) !important;
}

/* Touch target minimum size */
.vaani-touch-target {
  min-width: 56px;
  min-height: 56px;
}

