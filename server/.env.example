# ─── Vaani Server Configuration ───
# Copy this file to .env and fill in your API keys.

# Server port (required)
PORT=3001

# Gemini API Key (required — same key used in root .env as VITE_GEMINI_API_KEY)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Groq API Key (for Whisper cloud STT fallback)
GROQ_API_KEY=your_groq_key_here

# Optional: ElevenLabs API Key (for premium TTS — app works without it)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
