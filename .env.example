# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# MiniMax M2.7 — primary AI (replaces Gemini)
VITE_MINIMAX_API_KEY=your_minimax_api_key_here

# Gemini — optional fallback (no longer primary)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Groq — cloud speech-to-text (Whisper)
VITE_GROQ_API_KEY=your_groq_api_key_here

# ElevenLabs — premium text-to-speech
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Backend API URL (optional, defaults to http://localhost:3001)
VITE_API_URL=http://localhost:3001
